{
	"info": {
		"_postman_id": "inmobiliaria-api-2025",
		"name": "Asecontin API",
		"description": "Colección de endpoints del backend Asecontin. Admin requiere token JWT (obtener con Login o Register).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "token", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.data && json.data.token) {",
									"        pm.collectionVariables.set('token', json.data.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"tu-password\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login",
						"description": "Inicia sesión. Devuelve token, email, nombre, rol. El token se guarda en la variable de colección para los endpoints Admin."
					}
				},
				{
					"name": "Register (primer admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    if (json.data && json.data.token) {",
									"        pm.collectionVariables.set('token', json.data.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Administrador\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/register",
						"description": "Registra el primer administrador. Solo funciona si aún no hay usuarios."
					}
				}
			]
		},
		{
